# আপনার টেলিগ্রাম বট টোকেন (BotFather থেকে নিন)
BOT_TOKEN=your_bot_token_here

# অ্যাডমিন ইউজার আইডি (কমা দিয়ে একাধিক দেওয়া যাবে)
ADMIN_IDS=123456789

# বটের ইউজারনেম (@ছাড়া)
BOT_USERNAME=YourBotUsername

# Force join channels (comma separated, example: @channel1,@channel2)
FORCE_JOIN_CHANNELS=@yourchannel

# Hosted HTTPS URL for Telegram Mini App
MINI_APP_URL=https://your-domain.example/app

# Tutorial video or support video link
TUTORIAL_VIDEO_URL=https://youtube.com/watch?v=your_video_id

# ডেটাবেস ফাইলের পাথ
DATABASE_PATH=bot_database.db
